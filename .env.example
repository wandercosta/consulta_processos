# ─── Ambiente ──────────────────────────────────────────────────────────────────
# local | production
APP_ENV=local

# ─── Banco de Dados ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=consulta_processos
DB_USER=root
DB_PASS=
DB_CHARSET=utf8

# ─── API ───────────────────────────────────────────────────────────────────────
# Token Bearer exigido pelo Python para chamar os endpoints da API
API_TOKEN=SEU_TOKEN_SECRETO_AQUI
# URL base usada pelo Python para construir as chamadas à API
API_BASE_URL=http://localhost/processos_api/api

# ─── Painel Administrativo ─────────────────────────────────────────────────────
PAINEL_SENHA=senha_segura_aqui
