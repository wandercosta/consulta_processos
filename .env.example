# ─── Ambiente ──────────────────────────────────────────────────────────────────
# local | production
APP_ENV=local

# Prefixo de URL do projeto no servidor
# Local (subpasta):  APP_BASE_PATH=/processos_api
# Produção (raiz):   APP_BASE_PATH=
APP_BASE_PATH=/processos_api

# ─── Banco de Dados ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=consulta_processos
DB_USER=root
DB_PASS=
DB_CHARSET=utf8

# ─── API ───────────────────────────────────────────────────────────────────────
# Token Bearer exigido pelo Python para chamar os endpoints da API
API_TOKEN=SEU_TOKEN_SECRETO_AQUI
# URL base usada pelo Python para construir as chamadas à API
API_BASE_URL=http://localhost/processos_api/api

# ─── Painel Administrativo ─────────────────────────────────────────────────────
PAINEL_SENHA=senha_segura_aqui

# ─── Uploads ───────────────────────────────────────────────────────────────────
# Caminho relativo à raiz do projeto ou absoluto para salvar arquivos enviados pelo Python
# Relativo: uploads   |   Absoluto: /var/www/html/uploads
UPLOADS_PATH=uploads
